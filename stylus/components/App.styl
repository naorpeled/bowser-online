[data-component='App'] {
	position: relative;
	max-width: 900px;
	margin: 0 auto;

	+desktop() {
		padding: 60px 40px;
	}

	+mobile() {
		padding: 30px 20px;
	}

	> .header {
		margin-bottom: 2rem;

		> h1 {
			font-size: 1.75rem;
			font-weight: 300;
			color: $TEXT_SECONDARY;
			letter-spacing: -0.01em;

			> a {
				text-decoration: none;
				color: $TEXT_PRIMARY;
				font-weight: 600;
				transition: color 0.2s ease;

				&:hover {
					color: $ACCENT_SECONDARY;
				}
			}
		}
	}

	> .input-wrapper {
		position: relative;
		margin-bottom: 2.5rem;
		display: flex;
		align-items: center;

		> .input-prompt {
			position: absolute;
			left: 16px;
			color: $TEXT_MUTED;
			font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
			font-size: 0.9rem;
			pointer-events: none;
			user-select: none;
		}

		> input {
			width: 100%;
			height: 52px;
			padding: 0 20px 0 48px;
			border: 1px solid rgba(255, 255, 255, 0.08);
			border-radius: 10px;
			background-color: $BG_SECONDARY;
			font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'Inter', monospace;
			font-size: 0.9rem;
			color: $TEXT_PRIMARY;
			transition: border-color 0.2s ease;

			+placeholder() {
				color: $TEXT_MUTED;
				font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
			}

			&:focus {
				outline: none;
				border-color: rgba(255, 255, 255, 0.2);
			}
		}
	}

	> .result {
		display: grid;
		gap: 1.25rem;

		+desktop() {
			grid-template-columns: 1fr 1fr;
		}

		+mobile() {
			grid-template-columns: 1fr;
		}

		> .section {
			background: rgba($BG_SECONDARY, 0.7);
			backdrop-filter: blur(12px);
			-webkit-backdrop-filter: blur(12px);
			border-radius: 16px;
			border: 1px solid rgba(255, 255, 255, 0.06);
			padding: 1.25rem 1.5rem 1rem;
			transition: all 0.25s ease;
			animation: cardFadeIn 0.5s ease both;

			&:hover {
				border-color: rgba(255, 255, 255, 0.12);
				box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
				transform: translateY(-2px);
			}

			for i in 1..4 {
				&:nth-child({i}) {
					animation-delay: (i * 0.08)s;
				}
			}

			> .section-header {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				margin-bottom: 0.75rem;
				padding-bottom: 0.65rem;
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);

				> .section-icon {
					display: flex;
					align-items: center;
					justify-content: center;
					width: 28px;
					height: 28px;
					border-radius: 7px;
					background: rgba(255, 255, 255, 0.06);
					color: $TEXT_SECONDARY;
				}

				> h3 {
					font-size: 0.85rem;
					font-weight: 600;
					text-transform: uppercase;
					letter-spacing: 0.1em;
					color: $TEXT_SECONDARY;
				}
			}

			> .line {
				padding: 0.4rem 0;
				display: flex;
				flex-direction: column;
				gap: 0.25rem;

				> .item {
					color: $TEXT_MUTED;
					font-weight: 400;
					font-size: 0.7rem;
					text-transform: uppercase;
					letter-spacing: 0.04em;
				}

				> .value {
					color: $TEXT_PRIMARY;
					font-weight: 600;
					font-size: 1.05rem;
					word-break: break-word;

					> .value-with-icon {
						display: inline-flex;
						align-items: center;
						gap: 0.45rem;

						> .brand-icon {
							flex: 0 0 auto;
							width: 20px;
							height: 20px;
							opacity: 0.85;
						}
					}
				}
			}
		}
	}

	> .footer {
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		text-align: center;
		color: $TEXT_MUTED;
		font-size: 0.9rem;

		a {
			color: $TEXT_SECONDARY;
			text-decoration: none;
			transition: color 0.2s ease;

			&:hover {
				color: $ACCENT_PRIMARY;
			}
		}
	}
}

@keyframes cardFadeIn {
	from {
		opacity: 0;
		transform: translateY(16px) scale(0.98);
	}
	to {
		opacity: 1;
		transform: translateY(0) scale(1);
	}
}
